{
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/assign",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/td-sync",
      "schedule": "*/15 * * * 1-5"
    },
    {
      "path": "/api/propagate",
      "schedule": "*/30 * * * 1-5"
    }
  ]
}
